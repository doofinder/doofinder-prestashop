# Doofinder for PrestaShop – local setup
# Copy this file to .env and adjust values. Use production URLs only in this example.
# Optional: create .env.local to override vars (e.g. for local Doofinder dev); Makefile loads it after .env.

# -----------------------------------------------------------------------------
# Plugin version (used by doofinder-configure; also set $this->version in doofinder.php for PrestaShop)
# -----------------------------------------------------------------------------
PLUGIN_VERSION=8.0.6

# -----------------------------------------------------------------------------
# Doofinder service URLs (production). Used in src/Core/DoofinderConstants.php via make doofinder-configure.
# -----------------------------------------------------------------------------
DOOMANAGER_REGION_URL=https://admin.doofinder.com
DOOPLUGINS_REGION_URL=https://dooplugins.doofinder.com
DOOPHOENIX_REGION_URL=https://doophoenix.doofinder.com
CONFIG_REGION_URL=https://config.doofinder.com

# -----------------------------------------------------------------------------
# PrestaShop / store
# -----------------------------------------------------------------------------
# Public URL of your store (no trailing slash). For local Docker use e.g. localhost:4011 or your domain.
BASE_URL=localhost:4011

# -----------------------------------------------------------------------------
# MySQL (Docker db service)
# -----------------------------------------------------------------------------
MYSQL_VERSION=8.0
MYSQL_DATABASE=prestashop
MYSQL_USER=prestashop
MYSQL_PASSWORD=prestashop

# -----------------------------------------------------------------------------
# PrestaShop installer / runtime (Docker setup and prestashop services)
# -----------------------------------------------------------------------------
PRESTASHOP_DOCKER_TAG=8.2.1-8.1
PS_DB_PREFIX=ps_
PS_LANGUAGE=en
PS_COUNTRY=us
PS_FOLDER_ADMIN=4dm1n
PS_ENABLE_SSL=1
PS_ADMIN_EMAIL=test@example.com
PS_ADMIN_PASSWORD=admin123

# -----------------------------------------------------------------------------
# Optional: permissions for ./html after init (GID of your user if needed)
# -----------------------------------------------------------------------------
GID=1000

# -----------------------------------------------------------------------------
# Optional: Xdebug (docker-compose passes these to the web container)
# -----------------------------------------------------------------------------
# XDEBUG_HOST=host.docker.internal
# XDEBUG_KEY=DOOFINDER
